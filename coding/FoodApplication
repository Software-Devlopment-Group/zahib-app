        tk.Button(win, text="Add Item", command=add_item).pack(pady=5)
        tk.Button(win, text="Delete Item", command=delete_item).pack(pady=5)

    # ---------------- GENERATE REPORT ----------------
    def generate_report(self):
        cursor.execute("SELECT COUNT(*), SUM(total_price) FROM orders")
        data = cursor.fetchone()

        total_orders = data[0]
        total_revenue = data[1] if data[1] else 0

        self.output.delete("1.0", tk.END)
        self.output.insert(tk.END, f"Total Orders: {total_orders}\n")
        self.output.insert(tk.END, f"Total Revenue: {total_revenue}\n")


# ---------------- RUN APP ----------------
root = tk.Tk()
app = StaffAdminUI(root)
root.mainloop()